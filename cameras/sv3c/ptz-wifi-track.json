    "home_assistant": {
      "integration": "generic_camera",
      "notes": "Add via the generic RTSP/ONVIF camera integration."
    },
    "blue_iris": {
      "profile": "Generic/RTSP",
      "notes": "Use the Generic/RTSP (or ONVIF) profile."
    }
  },
  "power_source": [
